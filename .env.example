# Rased Plus frontend environment
# Copy this file to .env and put your real keys.

# Backend (optional). Leave empty to use local mock engine.
VITE_API_BASE_URL=

# Preferred: OpenRouter (supports free models like Nemotron)
VITE_OPENROUTER_API_KEY=your_openrouter_key_here
VITE_OPENROUTER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct:free

# Optional alternatives
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile
